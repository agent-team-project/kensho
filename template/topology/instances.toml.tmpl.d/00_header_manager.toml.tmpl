# Declared agent instances for this repo.
#
# `agent-team instance up` brings up every non-ephemeral instance declared
# below. Ephemeral instances (e.g. `worker`) spawn on-demand when their
# triggers match an inbound event.
#
# See `documentation/topology.md` (in the agent-team source repo) for the
# full schema, the layered config-resolution chain, and the match DSL. The
# defaults below mirror the bundled team's natural shape — edit / extend as
# your project grows.
#
# The shared policy is inherited by every instance and pipeline step unless an
# explicit declaration overrides it. Keep runtime/model/effort topology-owned
# so launches never depend on a developer's runtime user config.
[model_policy]
runtime = "codex"
model   = "gpt-5.6-sol"
effort  = "high"

# Per-instance runtime overrides are optional:
#   runtime     = "claude" | "codex" | "docker"
#   runtime_bin = "claude"
#   model       = "claude-fable-5"
#   effort      = "max"

[instances.manager]
agent       = "manager"
ephemeral   = false
description = "User-facing entry point. Coordinates workers, reviewers, and follow-up decisions."

[[instances.manager.triggers]]
event = "user_invocation"

[[instances.manager.triggers]]
event        = "agent.dispatch"
match.target = "manager"

[[instances.manager.triggers]]
event        = "job.step_completed"
match.target = "manager"

[[instances.manager.triggers]]
event        = "job.completed"
match.target = "manager"

[[instances.manager.triggers]]
event        = "deliverable.ready"
match.target = "manager"
