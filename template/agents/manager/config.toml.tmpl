# Skills available to the `manager` agent at runtime.
#
# Local skills under ./skills/ are auto-included (e.g. ./skills/assign-worker/).
# Pull in shared skills (under ../../skills/) by name, or anywhere by path:
# Team-wide shared skills belong in .agent_team/config.toml, not this file:
#   [skills]
#   team = ["linear", "github", "status"]
[skills]
{{ if eq .template.profile `full` -}}
extra = ["linear", "github", "status", "inbox", "channel", "traceability", "triage-feedback", "community-intake", "review-harness", "org-review", "release", "sentinel", "product-verify"]
{{ else -}}
extra = ["linear", "github", "status", "inbox", "channel", "traceability"]
{{ end -}}
# disable = []   # opt-out from local defaults if needed
