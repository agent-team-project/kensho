# budget_notice levels are the normal pacing mechanism.
# hard_multiplier = 1.5
description   = "Platform-team code writer for framework-infrastructure jobs."

[[instances.platform-worker.triggers]]
event        = "agent.dispatch"
match.target = "platform-worker"

[instances.platform-verifier]
agent        = "verifier"
ephemeral    = true
replicas     = 2
token_budget = "5M"
time_budget  = "20m"
description  = "Platform-team deterministic verifier."

[[instances.platform-verifier.triggers]]
event        = "agent.dispatch"
match.target = "platform-verifier"

[instances.platform-reviewer]
agent       = "reviewer"
ephemeral   = true
replicas    = 3
token_budget = "10M"
time_budget  = "30m"
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Platform-team adversarial reviewer."

[[instances.platform-reviewer.triggers]]
event        = "agent.dispatch"
match.target = "platform-reviewer"

[pipelines.platform_ticket_to_pr]
# Distinct trigger event: platform work is dispatched explicitly (`agent-team
# pipeline run platform_ticket_to_pr ...` or `event publish platform.ticket`),
# never by the delivery team's board column.
trigger.event = "platform.ticket"
auto_advance = true

[[pipelines.platform_ticket_to_pr.steps]]
id        = "implement"
target    = "platform-worker"
workspace = "worktree"
# Platform-team arcs are the big ones (three consecutive 30-45m+ implements);
# 60m observed-fit, and `job extend` remains the pressure valve.
timeout      = "60m"
token_budget = "40M"
time_budget  = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard_multiplier = 1.5
max_attempts = 1

[[pipelines.platform_ticket_to_pr.steps]]
id           = "verify"
target       = "platform-verifier"
after        = ["implement"]
workspace    = "repo"
timeout      = "20m"
token_budget = "5M"
time_budget  = "20m"
max_attempts = 1
retry_on_crash = true
instructions = """
Run the verify skill against the platform worker commit before LLM review.
Stream progress, write `target/agent-evidence/<job>.json`, record each gate
with `agent-team job gate set`, and advance only if every declared gate passes.

```agent-team-verify-gates
gofmt-check :: test -z "$(gofmt -l .)"
go-vet :: go vet ./...
go-test :: go test ./...
```
"""

[[pipelines.platform_ticket_to_pr.steps]]
id           = "review"
target       = "platform-reviewer"
after        = ["verify"]
timeout      = "30m"
token_budget = "10M"
time_budget  = "30m"
retry_on_crash = true
instructions = """
Adversarial content review of the platform job PR. Read the verifier evidence
first, then apply the delivery checklist beyond those scripted gates: verify
acceptance criteria against the ticket, hand-verify the changed behavior, and
judge content only (infra state and base drift are not content bounces). Report
gates with `agent-team job gate set`, then post `REVIEW: APPROVE` or
`REVIEW: BOUNCE` with findings as a PR comment.
"""

[[pipelines.platform_ticket_to_pr.steps]]
id           = "approve"
target       = "manager"
after        = ["review"]
gate         = "manual"
instructions = """
Read the reviewer's verdict and the diff. APPROVE + green gates: merge via
`agent-team job merge <job-id>` (or `gh pr merge`), close the ticket, mark
the job done. BOUNCE: `agent-team job bounce <job-id> --findings-file <path>
--advance`. Do not amend the branch yourself.
"""

[teams.platform]
description = "Framework infrastructure: provider seams, provenance, scoping, resource constraints."
instances   = ["platform-worker", "platform-verifier", "platform-reviewer", "manager"]
pipelines   = ["platform_ticket_to_pr"]


# The harness-review loop: a weekly sweep of the team's own steering surfaces
# (agent prompts, skills, pipeline instructions) driven by operational
# evidence — bounce-finding classes, attention events, feedback, failure
# patterns. Proposes improvement tickets (label `harness`, Backlog only);
# never edits prompts directly. See the review-harness skill.
[schedules.harness-review]
every = "8h" # daily while the fleet + prompts evolve fast; revisit at stability

[schedules.harness-review.payload]
kind = "harness_review"

[instances.harness-reviewer]
agent       = "manager"
ephemeral   = true
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Scheduled harness review: bounce/feedback/failure trends -> prompt and instruction improvement tickets."

[[instances.harness-reviewer.triggers]]
event      = "schedule"
match.name = "harness-review"
match.kind = "harness_review"


# The org-review loop: every few days, turn the outcomes ledger, spend,
# concurrency/capacity, bounce classes, cycle-time, and feedback trends into at
# most a few evidence-backed process/topology/prompt/budget tickets. It is the
# strategic complement to harness-review and never edits the system directly.
# See the org-review skill and documentation/metrics-methodology.md.
[schedules.org-review]
every = "72h" # 3d; schedule durations use Go duration syntax

[schedules.org-review.payload]
kind = "org_review"
task = "Run the org-review skill: analyze outcomes, spend, capacity, feedback, and review-loop health; file capped strategic improvement tickets."

[instances.org-review]
agent        = "manager"
ephemeral    = true
token_budget = "15M"
time_budget  = "45m"
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description  = "Scheduled org review: outcomes/spend/capacity/feedback -> strategic improvement tickets."

[[instances.org-review.triggers]]
event      = "schedule"
match.name = "org-review"
match.kind = "org_review"


# The sentinel loop: every six hours, check the post-merge public surface that
