# Declared agent instances for this repo.
#
# `agent-team instance up` brings up every non-ephemeral instance declared
# below. Ephemeral instances (e.g. `worker`) spawn on-demand when their
# triggers match an inbound event.
#
# See `documentation/topology.md` (in the agent-team source repo) for the
# full schema, the layered config-resolution chain, and the match DSL. The
# defaults below mirror the bundled team's natural shape — edit / extend as
# your project grows.
#
# The shared policy is inherited by every instance and pipeline step unless an
# explicit declaration overrides it. A runtime-family override clears inherited
# model/effort unless new selectors are declared beside it. Keep this triple
# topology-owned so launches never depend on a developer's runtime user config.
[model_policy]
runtime = "codex"
model   = "gpt-5.6-sol"
effort  = "xhigh"

# Per-instance runtime overrides are optional:
#   runtime     = "claude" | "codex" | "docker"
#   runtime_bin = "claude"
#   model       = "claude-fable-5"
#   effort      = "max"

[instances.manager]
agent       = "manager"
ephemeral   = false
description = "User-facing entry point. Coordinates workers, reviewers, and follow-up decisions."

[[instances.manager.triggers]]
event = "user_invocation"

[[instances.manager.triggers]]
event        = "agent.dispatch"
match.target = "manager"

[[instances.manager.triggers]]
event        = "job.step_completed"
match.target = "manager"

[[instances.manager.triggers]]
event        = "job.completed"
match.target = "manager"

[[instances.manager.triggers]]
event        = "deliverable.ready"
match.target = "manager"
{{ if eq .template.profile `full` -}}
[instances.ticket-manager]
agent       = "ticket-manager"
ephemeral   = false
description = "Reads, files, and triages Linear tickets in scope of this repo."

[[instances.ticket-manager.triggers]]
event = "user_invocation"
{{ end }}

[instances.worker]
agent         = "worker"
ephemeral     = true
replicas      = 4
reap_worktree = "on_merge"   # reap the job worktree + local branch after its PR merges; `agent-team job keep-worktree <id>` opts one job out
token_budget  = "40M"
time_budget   = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard = true
# hard_multiplier = 1.5
description   = "Code-writing agent. Spawned on `agent.dispatch` (see assign-worker skill)."

[[instances.worker.triggers]]
event        = "agent.dispatch"
match.target = "worker"

[instances.verifier]
agent        = "verifier"
ephemeral    = true
replicas     = 2
token_budget = "5M"
time_budget  = "20m"
description  = "Deterministic verifier. Runs declared gates against worker commits and writes machine-readable evidence before review."

[[instances.verifier.triggers]]
event        = "agent.dispatch"
match.target = "verifier"

[instances.reviewer]
agent       = "reviewer"
ephemeral   = true
replicas    = 3
token_budget = "10M"
time_budget  = "30m"
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Adversarial content reviewer for worker PRs. Reads, verifies, reports a verdict; never pushes."

[[instances.reviewer.triggers]]
event        = "agent.dispatch"
match.target = "reviewer"

# The field-proven pipeline shape (see documentation/operating-model.md):
# dragging a Linear card or GitHub Project item into the configured
# agent_column ("Ready for Agent" by default) is the dispatch gesture. The
# zero-config alternative is:
#   trigger.event = "ticket.created"
#   # remove trigger.match.status
#
# Headless implement -> deterministic verify -> adversarial review chain on
# process exit; the manual gate stops exactly where merge judgment is needed.
# Watchdog timeouts rescue wedged runtimes; implement keeps max_attempts = 1
# because a hang can strike after the PR opens and a retry would open a
# duplicate. Verify and review are read-only, so retry_on_crash allows one
# automatic retry only after a crash with no recorded result.
[pipelines.ticket_to_pr]
trigger.event = "ticket.status_changed"
trigger.match.status = "{{ if eq .pm.provider `github` }}{{ .github.agent_column }}{{ else }}{{ .linear.agent_column }}{{ end }}"
auto_advance  = true
redispatch_on_reentry = false

[pipelines.ticket_to_pr.infra_signatures]
github_project_token_missing = "(?i)(PROJECTS_TOKEN secret (missing|unset)|Set the PROJECTS_TOKEN secret|set PROJECTS_TOKEN, GH_TOKEN, or GITHUB_TOKEN)"
github_token_missing = "(?i)no GitHub token found"

[[pipelines.ticket_to_pr.steps]]
id           = "implement"
target       = "worker"
workspace    = "worktree"
timeout      = "45m"
token_budget = "40M"
time_budget  = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard_multiplier = 1.5
max_attempts = 1

[[pipelines.ticket_to_pr.steps]]
id           = "verify"
target       = "verifier"
after        = ["implement"]
workspace    = "repo"
timeout      = "20m"
token_budget = "5M"
time_budget  = "20m"
max_attempts = 1
retry_on_crash = true
instructions = """
Run the verify skill against the worker commit before LLM review. Stream
progress, write `target/agent-evidence/<job>.json`, record each gate with
`agent-team job gate set`, and advance only if every declared gate passes.
These declared gates are the smoke tier from `.agent_team/gates.toml`; do not
claim acceptance or release readiness unless the required tier evidence exists.

```agent-team-verify-gates
gofmt-check :: test -z "$(gofmt -l .)"
go-vet :: go vet ./...
go-test :: go test ./...
```
"""

[[pipelines.ticket_to_pr.steps]]
id           = "review"
target       = "reviewer"
after        = ["verify"]
timeout      = "30m"
token_budget = "10M"
time_budget  = "30m"
max_attempts = 1
retry_on_crash = true
instructions = """
Read `target/agent-evidence/<job>.json` and the durable job contract first,
then hand-verify: (1) each contract criterion is actually met — check the
specific behaviors, not the PR description; (2) tests cover the changed
behavior and would fail without the change; (3) no unrelated files or drive-by
edits; (4) no dead code or commented-out blocks. Judge CONTENT outside the
scripted verifier gates: infra failures are gate results, not bounces, and base
drift is not a bounce. Report via `agent-team job gate set` and a PR comment
starting `REVIEW: APPROVE` with a clause-keyed ledger or `REVIEW: BOUNCE` with
each finding starting `clause=ACn` or `clause=none`.
"""

# The manual gate: nothing merges without human (or manager) judgment. To make
# an explicit approval artifact mandatory before this step can advance, add
# `approval_required = true` and pair it with `agent-team approval request`.
[[pipelines.ticket_to_pr.steps]]
id           = "approve"
target       = "manager"
after        = ["review"]
gate         = "manual"
instructions = """
Read the reviewer's verdict and the diff. If REVIEW: APPROVE and gates are
green, merge with `agent-team job merge <job-id>` (or `gh pr merge`), close the
ticket, and mark the job done. If REVIEW: BOUNCE, run `agent-team job bounce
<job-id> --findings-file <path> --advance` so the worker gets the findings in
kickoff — do not amend the branch yourself.
"""
{{ if eq .template.profile `full` }}

# The feedback-triage loop: agents submit one-line observations mid-job
# (`agent-team feedback submit` — see the triage-feedback skill); this weekly
# schedule spawns an ephemeral manager that clusters new feedback plus system
# pain signals (repeated bounces, infra-signature repeats) and materializes
# tickets, folds evidence into existing ones, or dismisses with a reason.
# Filed tickets land in Backlog — never the agent-dispatch column.
[schedules.feedback-triage]
every = "6h"

[schedules.feedback-triage.payload]
kind = "feedback_triage"

[instances.feedback-triage]
agent       = "manager"
ephemeral   = true
description = "Scheduled feedback triage: local store + system signals -> tickets/folds/dismissals."

[[instances.feedback-triage.triggers]]
event      = "schedule"
match.name = "feedback-triage"
match.kind = "feedback_triage"


# The quality team: a scheduled auditor that sweeps one subsystem per run and
# files evidence-backed tech-debt tickets (at most three, Backlog only). The
# counterweight to delivery velocity — see template/agents/auditor/agent.md.
[schedules.debt-sweep]
every = "24h" # weekly

[schedules.debt-sweep.payload]
kind = "debt_sweep"

[instances.debt-auditor]
agent       = "auditor"
ephemeral   = true
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Scheduled architecture/tech-debt audit: one subsystem per run, evidence-backed tickets."

[[instances.debt-auditor.triggers]]
event      = "schedule"
match.name = "debt-sweep"
match.kind = "debt_sweep"

[[instances.debt-auditor.triggers]]
event        = "agent.dispatch"
match.target = "debt-auditor"


# The platform team: framework-infrastructure arcs (provider seams, provenance,
# scoping) run through their own worker/verifier/reviewer pool so product
# delivery and platform work scale independently.
[instances.platform-worker]
agent         = "worker"
ephemeral     = true
replicas      = 3
reap_worktree = "on_merge"
token_budget  = "40M"
time_budget   = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard_multiplier = 1.5
description   = "Platform-team code writer for framework-infrastructure jobs."

[[instances.platform-worker.triggers]]
event        = "agent.dispatch"
match.target = "platform-worker"

[instances.platform-verifier]
agent        = "verifier"
ephemeral    = true
replicas     = 2
token_budget = "5M"
time_budget  = "20m"
description  = "Platform-team deterministic verifier."

[[instances.platform-verifier.triggers]]
event        = "agent.dispatch"
match.target = "platform-verifier"

[instances.platform-reviewer]
agent       = "reviewer"
ephemeral   = true
replicas    = 3
token_budget = "10M"
time_budget  = "30m"
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Platform-team adversarial reviewer."

[[instances.platform-reviewer.triggers]]
event        = "agent.dispatch"
match.target = "platform-reviewer"

[pipelines.platform_ticket_to_pr]
# Distinct trigger event: platform work is dispatched explicitly (`agent-team
# pipeline run platform_ticket_to_pr ...` or `event publish platform.ticket`),
# never by the delivery team's board column.
trigger.event = "platform.ticket"
auto_advance = true

[pipelines.platform_ticket_to_pr.infra_signatures]
github_project_token_missing = "(?i)(PROJECTS_TOKEN secret (missing|unset)|Set the PROJECTS_TOKEN secret|set PROJECTS_TOKEN, GH_TOKEN, or GITHUB_TOKEN)"
github_token_missing = "(?i)no GitHub token found"

[[pipelines.platform_ticket_to_pr.steps]]
id        = "implement"
target    = "platform-worker"
workspace = "worktree"
# Platform-team arcs are the big ones (three consecutive 30-45m+ implements);
# 60m observed-fit, and `job extend` remains the pressure valve.
timeout      = "60m"
token_budget = "40M"
time_budget  = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard_multiplier = 1.5
max_attempts = 1

[[pipelines.platform_ticket_to_pr.steps]]
id           = "verify"
target       = "platform-verifier"
after        = ["implement"]
workspace    = "repo"
timeout      = "20m"
token_budget = "5M"
time_budget  = "20m"
max_attempts = 1
retry_on_crash = true
instructions = """
Run the verify skill against the platform worker commit before LLM review.
Stream progress, write `target/agent-evidence/<job>.json`, record each gate
with `agent-team job gate set`, and advance only if every declared gate passes.
These declared gates are the smoke tier from `.agent_team/gates.toml`; do not
claim acceptance or release readiness unless the required tier evidence exists.

```agent-team-verify-gates
gofmt-check :: test -z "$(gofmt -l .)"
go-vet :: go vet ./...
go-test :: go test ./...
```
"""

[[pipelines.platform_ticket_to_pr.steps]]
id           = "review"
target       = "platform-reviewer"
after        = ["verify"]
timeout      = "30m"
token_budget = "10M"
time_budget  = "30m"
retry_on_crash = true
instructions = """
Adversarial content review of the platform job PR. Read the verifier evidence
first, then apply the delivery checklist beyond those scripted gates: verify
contract criteria against the durable job contract, hand-verify the changed
behavior, and judge content only (infra state and base drift are not content
bounces). Report gates with `agent-team job gate set`, then post
`REVIEW: APPROVE` with a clause-keyed ledger or `REVIEW: BOUNCE` with each
finding starting `clause=ACn` or `clause=none`.
"""

[[pipelines.platform_ticket_to_pr.steps]]
id           = "approve"
target       = "manager"
after        = ["review"]
gate         = "manual"
instructions = """
Read the reviewer's verdict and the diff. APPROVE + green gates: merge via
`agent-team job merge <job-id>` (or `gh pr merge`), close the ticket, mark
the job done. BOUNCE: `agent-team job bounce <job-id> --findings-file <path>
--advance`. Do not amend the branch yourself.
"""

[teams.platform]
description = "Framework infrastructure: provider seams, provenance, scoping, resource constraints."
instances   = ["platform-worker", "platform-verifier", "platform-reviewer", "manager"]
pipelines   = ["platform_ticket_to_pr"]
# The harness-review loop: a weekly sweep of the team's own steering surfaces
# (agent prompts, skills, pipeline instructions) driven by operational
# evidence — bounce-finding classes, attention events, feedback, failure
# patterns. Proposes improvement tickets (label `harness`, Backlog only);
# never edits prompts directly. See the review-harness skill.
[schedules.harness-review]
every = "8h" # daily while the fleet + prompts evolve fast; revisit at stability

[schedules.harness-review.payload]
kind = "harness_review"

[instances.harness-reviewer]
agent       = "manager"
runtime     = "claude"
model       = "claude-fable-5"
effort      = "max"
ephemeral   = true
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Scheduled harness review on Fable max effort: bounce/feedback/failure trends -> prompt and instruction improvement tickets."

[[instances.harness-reviewer.triggers]]
event      = "schedule"
match.name = "harness-review"
match.kind = "harness_review"


# The org-review loop: every few days, turn the outcomes ledger, spend,
# concurrency/capacity, bounce classes, cycle-time, and feedback trends into at
# most a few evidence-backed process/topology/prompt/budget tickets. It is the
# strategic complement to harness-review and never edits the system directly.
# See the org-review skill and documentation/metrics-methodology.md.
[schedules.org-review]
every = "72h" # 3d; schedule durations use Go duration syntax

[schedules.org-review.payload]
kind = "org_review"
task = "Run the org-review skill: analyze outcomes, spend, capacity, feedback, and review-loop health; file capped strategic improvement tickets."

[instances.org-review]
agent        = "manager"
runtime      = "claude"
model        = "claude-fable-5"
effort       = "max"
ephemeral    = true
token_budget = "15M"
time_budget  = "45m"
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description  = "Scheduled org review on Fable max effort: outcomes/spend/capacity/feedback -> strategic improvement tickets."

[[instances.org-review.triggers]]
event      = "schedule"
match.name = "org-review"
match.kind = "org_review"


# The advisor is the persistent Fable exception for hard, high-leverage
# reasoning. It is advisory only and does not participate in delivery lanes.
[instances.advisor]
agent        = "advisor"
runtime      = "claude"
model        = "claude-fable-5"
effort       = "max"
ephemeral    = false
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description  = "Persistent Fable max effort reasoning consultant for hard architecture and strategy calls."

[[instances.advisor.triggers]]
event = "user_invocation"

[[instances.advisor.triggers]]
event        = "agent.dispatch"
match.target = "advisor"


# The sentinel loop: every six hours, check the post-merge public surface that
# reviewers cannot see from a green PR alone — main CI, Read the Docs build and
# rendered pages, release assets, and repo metadata. Failures are submitted as
# incident feedback immediately. See the sentinel skill.
[schedules.sentinel]
every = "6h"
run_on_start = true

[schedules.sentinel.payload]
kind = "sentinel"

[instances.sentinel]
agent        = "manager"
ephemeral    = true
token_budget = "10M"
time_budget  = "15m"
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK", "AGENT_TEAM_GITHUB_TOKEN", "GITHUB_TOKEN", "GH_TOKEN"]
description  = "Scheduled production sentinel: main CI, RTD rendering, release assets, and repo metadata."

[[instances.sentinel.triggers]]
event      = "schedule"
match.name = "sentinel"
match.kind = "sentinel"


# The product-verifier loop: a headless synthetic user checks daemon UI data
# against CLI ground truth, then files capped feedback for bugs, friction, and
# ideas. See template/skills/product-verify/SKILL.md.
[schedules.product-verify]
every = "24h"

[schedules.product-verify.payload]
kind = "product_verify"
task = "Run the product-verify skill: compare daemon UI endpoints with CLI ground truth and file capped feedback findings."

[instances.product-verifier]
agent        = "manager"
ephemeral    = true
token_budget = "10M"
time_budget  = "30m"
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK", "AGENT_TEAM_ROOT", "AGENT_TEAM_DAEMON_URL", "AGENT_TEAM_BIN", "PYTHONPATH"]
description  = "Scheduled product verifier: headless UI-vs-CLI correctness plus UX feedback."

[[instances.product-verifier.triggers]]
event      = "schedule"
match.name = "product-verify"
match.kind = "product_verify"
# The comms team: the project's public voice. A 24h schedule offers a digest
# opportunity; the shared webhook helper enforces one success per rolling 24h
# across digest, release, and manual paths. Quiet windows remain quiet and
# ineligible material is retained. Community signal flows back through the
# feedback store. See template/agents/comms/agent.md for the voice rules.
[schedules.discord-digest]
every = "24h"

[schedules.discord-digest.payload]
kind = "discord_digest"

[instances.comms]
agent        = "comms"
ephemeral    = true
token_budget = "15M"
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description  = "Public-relations agent: 24-hour-capped shipped-work digest, release announcements, community intake."

[[instances.comms.triggers]]
event      = "schedule"
match.name = "discord-digest"
match.kind = "discord_digest"

[[instances.comms.triggers]]
event        = "agent.dispatch"
match.target = "comms"

# The release lane is manual-only: no schedule or PM-column trigger starts it.
# Operators start it explicitly, for example:
#   agent-team pipeline run release v0.5.0 --id release-v0.5.0 --dispatch
[instances.release-worker]
agent         = "worker"
ephemeral     = true
replicas      = 1
reap_worktree = "on_merge"
token_budget  = "40M"
time_budget   = "45m"
description   = "Release-lane worker for changelog/version prep, verification, tag shipping, and asset checks."

[[instances.release-worker.triggers]]
event        = "agent.dispatch"
match.target = "release-worker"

[pipelines.release]
trigger.event = "release.requested"
auto_advance  = true
redispatch_on_reentry = false
reap_worktree = "on_merge"

[[pipelines.release.steps]]
id           = "prepare"
label        = "Prepare"
target       = "release-worker"
workspace    = "worktree"
timeout      = "45m"
token_budget = "40M"
time_budget  = "45m"
max_attempts = 1
instructions = """
Use the release skill. Draft the changelog from merged PRs since the last tag,
bump release/version references for the requested version, and open or update
the release PR. Include the API-cleanup sweep gate (SQU-138 in the agent-team
board) as done, blocking, or explicitly deferred before this step is marked
done. Do not tag or publish.
"""

[[pipelines.release.steps]]
id           = "verify"
label        = "Verify"
target       = "release-worker"
after        = ["prepare"]
workspace    = "worktree"
timeout      = "45m"
token_budget = "40M"
time_budget  = "45m"
max_attempts = 1
instructions = """
Use the release skill. Run the release verification gate against the release PR:
GoReleaser snapshot dry-run, the full repository suite, smoke, generated CLI
docs check, and docs build. Record every gate result on the job. Do not tag or
publish.
"""

[[pipelines.release.steps]]
id           = "approve"
label        = "Approve"
target       = "manager"
after        = ["verify"]
gate         = "manual"
timeout      = "30m"
token_budget = "10M"
time_budget  = "30m"
instructions = """
Manual release decision. Read the release PR, changelog, SQU-138 gate status,
and verify-step gate ledger. If approved, merge the release PR into main and
mark this step done/advance so ship can tag exactly what was approved. If not
approved, leave the job held or reject with the reason.
"""

[[pipelines.release.steps]]
id           = "ship"
label        = "Ship"
target       = "release-worker"
after        = ["approve"]
workspace    = "worktree"
timeout      = "45m"
token_budget = "40M"
time_budget  = "45m"
max_attempts = 1
instructions = """
Use the release skill. After approval has merged the release PR, fetch main,
create and push the release tag, watch the GitHub release workflow, then verify
the four platform tarball assets are downloadable from the GitHub release and
emit the daemon self-upgrade checklist. Do not draft or post the public
announcement from this step.
"""

[[pipelines.release.steps]]
id           = "announce"
label        = "Announce"
target       = "comms"
after        = ["ship"]
workspace    = "repo"
timeout      = "30m"
token_budget = "15M"
time_budget  = "30m"
max_attempts = 1
instructions = """
Use the release skill and existing comms digest machinery in release-announcement
mode. Draft the release announcement from the merged changelog and GitHub
release notes, then call the shared Discord boundary with kind `release` and
stable delivery id `release:<tag>`. Releases never bypass its rolling 24-hour
ceiling; the helper owns durable deferral and supervisor notification. Never
post through worker-owned automation or a user account.
"""

[instances.docs-writer]
agent        = "worker"
ephemeral    = true
runtime      = "codex"
token_budget = "40M"
description  = "Documentation writer on the claude runtime (subscription Opus-class prose). Dispatched for README/guide/narrative work."

[[instances.docs-writer.triggers]]
event        = "agent.dispatch"
match.target = "docs-writer"

# The docs team's freshness loop: weekly, the docs-writer audits docs against
# the shipped binary + latest release and files a stale-docs ticket (or is
# dispatched to fix directly). See the docs-freshness skill.
[schedules.docs-freshness]
every = "24h"

[schedules.docs-freshness.payload]
kind = "docs_freshness"
ticket = "GH-228"
ticket_url = "https://github.com/{{ .github.owner }}/{{ .github.repo }}/issues/228"
deliverable = "none"
kickoff = """
Scheduled docs-freshness audit for GitHub issue #228.

Use the docs-freshness skill in scheduled sweep/audit mode. Audit the docs
against code, generated CLI output, and release ground truth, then fold findings
into the existing stale-docs issue #228 with a top-level issue comment. Do not
open duplicate stale-docs issues. This is an audit/fold job with no PR
deliverable; only open a PR if a human later redispatches implementation work
explicitly.
"""

[pipelines.docs_freshness]
trigger.event = "schedule"
trigger.match.name = "docs-freshness"
trigger.match.kind = "docs_freshness"
redispatch_on_reentry = true
reap_worktree = "on_close"

[[pipelines.docs_freshness.steps]]
id = "audit"
target = "docs-writer"
workspace = "worktree"
timeout = "45m"
token_budget = "40M"
time_budget = "45m"
max_attempts = 1
instructions = """
Run the docs-freshness skill in scheduled audit mode. Keep findings folded into
GitHub issue #228 and do not create duplicate docs tickets. When the issue
comment/report is posted, let the job finish without opening a PR.
"""
# Standing empirical software-research organization. Research execution is
# pipeline-only: the persistent manager selects safe waves, independent seats
# verify and review them, and manual gates retain activation/integration
# judgment. Token capacity is deliberately high; the research charter's
# coupling, WIP, and absorption rules control actual width.
[instances.research-manager]
agent         = "manager"
ephemeral     = false
brief         = true
token_budget  = "100M"
time_budget   = "2h"
description   = "Persistent research director: study portfolio, safe waves, evidence synthesis, and framework-improvement loop."

[[instances.research-manager.triggers]]
event = "user_invocation"

[[instances.research-manager.triggers]]
event        = "agent.dispatch"
match.target = "research-manager"

[[instances.research-manager.triggers]]
event      = "schedule"
match.name = "research-reconcile"
match.kind = "research_reconcile"

[[instances.research-manager.triggers]]
event        = "job.step_completed"
match.target = "research-manager"

# Terminal and deliverable wakes remain pipeline-owned even though the daemon
# addresses their payload to the declared manual decision owner. This avoids
# duplicate rules and keeps the user-facing manager out of research results.
[[instances.research-manager.triggers]]
event          = "job.completed"
match.pipeline = "research_study"

[[instances.research-manager.triggers]]
event          = "job.completed"
match.pipeline = "research_slice"

[[instances.research-manager.triggers]]
event          = "deliverable.ready"
match.pipeline = "research_study"

[[instances.research-manager.triggers]]
event          = "deliverable.ready"
match.pipeline = "research_slice"

[instances.research-worker]
agent         = "worker"
ephemeral     = true
replicas      = 8
token_budget  = "80M"
time_budget   = "90m"
description   = "Research product/study worker. Executes only declared research pipeline steps with explicit evidence contracts."

[[instances.research-worker.triggers]]
event        = "agent.dispatch"
match.target = "research-worker"

[instances.research-verifier]
agent         = "verifier"
ephemeral     = true
replicas      = 3
token_budget  = "15M"
time_budget   = "30m"
description   = "Deterministic research verifier: reproduces product/study gates and emits canonical evidence before review."

[[instances.research-verifier.triggers]]
event        = "agent.dispatch"
match.target = "research-verifier"

[instances.research-reviewer]
agent         = "reviewer"
ephemeral     = true
replicas      = 3
token_budget  = "30M"
time_budget   = "45m"
description   = "Independent research reviewer: adversarial product semantics, evidence integrity, and falsification review."

[[instances.research-reviewer.triggers]]
event        = "agent.dispatch"
match.target = "research-reviewer"

[instances.research-auditor]
agent         = "reviewer"
ephemeral     = false
brief         = true
token_budget  = "20M"
time_budget   = "45m"
description   = "Persistent read-only evidence auditor: freezes preregistration digests and reconciles claims against canonical evidence."

[[instances.research-auditor.triggers]]
event = "user_invocation"

[[instances.research-auditor.triggers]]
event        = "agent.dispatch"
match.target = "research-auditor"

[[instances.research-auditor.triggers]]
event      = "schedule"
match.name = "research-evidence-audit"
match.kind = "research_evidence_audit"

[schedules.research-reconcile]
every = "2h"
run_on_start = true

[schedules.research-reconcile.payload]
kind   = "research_reconcile"
target = "research-manager"
task   = "Reconcile the active research portfolio from canonical repo/job/gate evidence. Dispatch graph-safe work, record a concrete hold/block, or close the checkpoint; never silently depend on an external manager wake."

[schedules.research-evidence-audit]
every = "84h"

[schedules.research-evidence-audit.payload]
kind   = "research_evidence_audit"
target = "research-auditor"
task   = "Audit active and newly terminal studies against frozen preregistration digests, durable jobs, gates, repository state, and artifact digests. Block unsupported research verdicts without blocking product releases."

# Study registration is evidence work, not product implementation. It freezes
# hypotheses, oracles, gates, falsifiers, and the topology snapshot first.
[pipelines.research_study]
trigger.event = "research.study.requested"
auto_advance = true
redispatch_on_reentry = false
reap_worktree = "on_close"

[[pipelines.research_study.steps]]
id           = "preregister"
target       = "research-worker"
workspace    = "worktree"
timeout      = "90m"
token_budget = "80M"
time_budget  = "90m"
max_attempts = 1
instructions = """
Produce only the study's declared preregistration/report deliverable. Freeze
product behavior, objective oracles, hard gates, process hypotheses, metrics,
falsifiers, topology/budget, evidence schema, confounders, and any shadow
requirements-graph experiment before implementation. Pin claims to source
commits and canonical job/gate/repo evidence. Do not implement product code,
open a PR, or bypass downstream verification/review.
"""

[[pipelines.research_study.steps]]
id           = "verify"
target       = "research-verifier"
after        = ["preregister"]
workspace    = "repo"
timeout      = "30m"
token_budget = "15M"
time_budget  = "30m"
max_attempts = 1
retry_on_crash = true
instructions = """
Verify the exact preregistration artifact recorded by the job. Check source
commit/digest claims, required sections, objective gate commands, closed
vocabularies, graph references, and internal consistency. Record every check as
a durable gate and attach reproducible evidence. Do not edit the artifact.

```agent-team-verify-gates
report-artifact :: r="${AGENT_TEAM_REPORT_PATH:-${AGENT_TEAM_DELIVERABLE#report:}}"; p="${AGENT_TEAM_ROOT%/.agent_team}/$r"; test -n "$r" && test -s "$p" && { if command -v sha256sum >/dev/null 2>&1; then sha256sum "$p"; else shasum -a 256 "$p"; fi; } > "$AGENT_TEAM_GATE_EVIDENCE_DIR/report.sha256"
report-verdict-separation :: r="${AGENT_TEAM_REPORT_PATH:-${AGENT_TEAM_DELIVERABLE#report:}}"; p="${AGENT_TEAM_ROOT%/.agent_team}/$r"; rg -qi 'product verdict' "$p" && rg -qi '(Kensho|process) verdict' "$p"
report-preregistration-contract :: r="${AGENT_TEAM_REPORT_PATH:-${AGENT_TEAM_DELIVERABLE#report:}}"; p="${AGENT_TEAM_ROOT%/.agent_team}/$r"; rg -qi 'hypothes' "$p" && rg -qi 'falsif' "$p" && rg -qi 'hard gate' "$p" && rg -qi 'requirements[- ]graph' "$p" && rg -qi '(activate|revise|stop)' "$p"
```
"""

[[pipelines.research_study.steps]]
id           = "review"
target       = "research-reviewer"
after        = ["verify"]
workspace    = "repo"
timeout      = "45m"
token_budget = "30M"
time_budget  = "45m"
max_attempts = 1
retry_on_crash = true
instructions = """
Adversarially review the preregistration after verifier success. Judge whether
hypotheses are genuinely falsifiable, product/process verdicts are separated,
metrics cannot be gamed, baseline evidence is not overclaimed, the proposed
parallel waves respect coupling seams, and the requirements graph remains a
shadow hypothesis rather than an unearned control-plane mandate. Report an
APPROVE or clause-keyed BOUNCE through the durable review gate. Do not edit.
"""

[[pipelines.research_study.steps]]
id           = "activate"
target       = "research-manager"
after        = ["review"]
gate         = "manual"
instructions = """
Activate the study only when the report deliverable exists and verifier/reviewer
evidence is green. Record the study in the cumulative ledger and open only the
first graph-safe implementation/checkpoint waves through `research_slice`. On
bounce, use the durable job bounce path. Never dispatch ungated product work.
"""

# Release-bearing implementation uses the ordinary verify/review discipline.
[pipelines.research_slice]
trigger.event = "research.slice.ready"
auto_advance = true
redispatch_on_reentry = false
reap_worktree = "on_merge"

[[pipelines.research_slice.steps]]
id           = "implement"
target       = "research-worker"
workspace    = "worktree"
timeout      = "90m"
token_budget = "80M"
time_budget  = "90m"
max_attempts = 1
instructions = """
Implement exactly one preregistered study slice against its pinned requirement,
acceptance nodes, source revision, integration duty, and focused gates. Produce
the declared branch/PR plus evidence manifest. Do not weaken gates, broaden
scope, or dispatch follow-on work directly.
"""

[[pipelines.research_slice.steps]]
id           = "verify"
target       = "research-verifier"
after        = ["implement"]
workspace    = "repo"
timeout      = "30m"
token_budget = "15M"
time_budget  = "30m"
max_attempts = 1
retry_on_crash = true
instructions = """
Reproduce the slice's declared focused and integration gates against the exact
worker commit. Emit structured evidence with commands, environment, timestamps,
results, counts, artifact digests, and requirement-node references. Do not edit
product code.
"""

[[pipelines.research_slice.steps]]
id           = "review"
target       = "research-reviewer"
after        = ["verify"]
workspace    = "repo"
timeout      = "45m"
token_budget = "30M"
time_budget  = "45m"
max_attempts = 1
retry_on_crash = true
instructions = """
Review content and claims independently after verifier success. Check the pinned
requirement/acceptance nodes, semantic edge cases, integration obligations,
test sensitivity, evidence integrity, and scope. Report APPROVE or clause-keyed
BOUNCE; never push fixes.
"""

[[pipelines.research_slice.steps]]
id           = "integrate"
target       = "research-manager"
after        = ["review"]
gate         = "manual"
instructions = """
Integrate only on green verifier/reviewer evidence and a clean canonical
requirements-graph reconciliation. Record accepted evidence and update the
study ledger. Bounce through the durable findings path; do not amend a worker
branch. Keep cross-cutting, security, contract, and release claims manual in v1.
"""

[teams.research]
description = "Standing empirical software studies: local products, preregistered hypotheses, mandatory verification/review, and cross-study learning."
instances   = ["research-manager", "research-worker", "research-verifier", "research-reviewer", "research-auditor"]
pipelines   = ["research_study", "research_slice"]
schedules   = ["research-reconcile", "research-evidence-audit"]

[budgets.research]
# Research is evidence-limited, not token-limited. Release-bearing WIP starts
# at four and may expand to six only after measured healthy waves.
tokens_per_day = 100_000_000_000
jobs_in_flight = 16

[teams.pr]
description = "Public relations: community digests, announcements, discussions, outward feedback intake."
instances   = ["comms"]
schedules   = ["discord-digest"]

[teams.release]
description = "Manual release train: prepare, verify, approve, tag, asset-check, and announce."
instances   = ["release-worker", "manager", "comms"]
pipelines   = ["release"]

[teams.docs]
description = "Documentation: README/guide/narrative authoring on the claude runtime, plus a weekly freshness audit against the shipped binary and latest release."
instances   = ["docs-writer"]
pipelines   = ["docs_freshness"]
schedules   = ["docs-freshness"]

[teams.quality]
description = "Proactive architecture, tech-debt, harness auditing, production sentinel checks, and product verification."
instances   = ["debt-auditor", "harness-reviewer", "org-review", "sentinel", "product-verifier"]
schedules   = ["debt-sweep", "harness-review", "org-review", "sentinel", "product-verify"]

{{ end }}
[teams.delivery]
description = "Default software-delivery team for ticket intake, implementation, review, and merge."
{{ if eq .template.profile `full` -}}
instances   = ["manager", "ticket-manager", "worker", "verifier", "reviewer", "feedback-triage"]
pipelines   = ["ticket_to_pr"]
schedules   = ["feedback-triage"]
{{ else -}}
instances   = ["manager", "worker", "verifier", "reviewer"]
pipelines   = ["ticket_to_pr"]
{{ end }}

# Optional per-team admission budgets. When omitted, dispatch behavior is
# unchanged. Token spend is computed from finalized usage records over the last
# 24 hours; in-flight jobs are counted by the job origin team.
# [budgets.delivery]
# tokens_per_day = 200_000_000
# jobs_in_flight = 6
# allocation = "oversubscribe" # default; "reserve" debits outstanding grants
# load_weight = 1.0          # default; higher values consume more concurrency headroom per dispatch

# Optional daemon-wide adaptive concurrency governor. When enabled, ephemeral
# dispatches queue once daemon-wide running instances reach the lower of the
# AIMD ceiling and the current machine-load ceiling. The load ceiling uses
# total system load, so external builds sharing the box reduce headroom too.
# [concurrency]
# enabled = true
# min_ceiling = 1
# max_ceiling = 8
# initial_ceiling = 4
# target_load_per_core = 0.85
# load_per_dispatch = 1.0
# crash_window = "10m"
# crash_threshold = 3
# decrease_factor = 0.5
# stable_window = "20m"
# increase_step = 1

# Optional resource scoping. Omitted scope defaults to "machine", preserving
# today's flat namespace. Use "team" when each owning team needs an isolated
# channel/schedule/lock key, and "job" for per-job state.
#
# [locks.build]
# slots = 1
# scope = "machine"
#
# [channels.supervisor]
# scope = "team"
# # Add "supervisor" to [teams.<name>].channels to declare ownership.
#
[authority]
enforcement = "audit"

[authority.instances.manager]
allow = ["*"]

{{ if eq .template.profile `full` }}
[authority.instances.research-manager]
allow = ["event.publish", "job.events", "job.gate.*:own", "job.step:own", "job.bounce:own", "job.close:own", "job.merge:own", "read", "ticket.create", "ticket.comment", "ticket.update"]

[authority.instances.research-auditor]
allow = ["read"]
{{ end }}

[authority.agents.worker]
allow = ["budget.status", "channel.*", "event.publish", "feedback.*", "inbox.*", "job.events", "job.gate.*:own", "job.show", "job.step:own", "status.*"]

[authority.agents.verifier]
allow = ["budget.status", "channel.*", "event.publish", "feedback.*", "inbox.*", "job.events", "job.gate.*:own", "job.show", "job.step:own", "status.*"]

[authority.agents.reviewer]
allow = ["budget.status", "channel.*", "feedback.*", "inbox.*", "job.events", "job.gate.*:own", "job.show", "status.*"]

[authority.agents.manager]
allow = ["budget.status", "channel.*", "feedback.*", "inbox.*", "job.show", "status.*"]

{{ if eq .template.profile `full` }}
[authority.agents.ticket-manager]
allow = ["budget.status", "channel.*", "feedback.*", "inbox.*", "job.show", "status.*"]

[authority.agents.auditor]
allow = ["budget.status", "channel.*", "feedback.*", "inbox.*", "job.show", "status.*"]

