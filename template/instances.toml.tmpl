# Declared agent instances for this repo.
#
# `agent-team instance up` brings up every non-ephemeral instance declared
# below. Ephemeral instances (e.g. `worker`) spawn on-demand when their
# triggers match an inbound event.
#
# See `documentation/topology.md` (in the agent-team source repo) for the
# full schema, the layered config-resolution chain, and the match DSL. The
# defaults below mirror the bundled team's natural shape — edit / extend as
# your project grows.

[instances.manager]
agent       = "manager"
ephemeral   = false
description = "User-facing entry point. Coordinates workers, reviewers, and follow-up decisions."

[[instances.manager.triggers]]
event = "user_invocation"

[[instances.manager.triggers]]
event        = "agent.dispatch"
match.target = "manager"

{{ if eq .template.profile `full` -}}
[instances.ticket-manager]
agent       = "ticket-manager"
ephemeral   = false
description = "Reads, files, and triages Linear tickets in scope of this repo."

[[instances.ticket-manager.triggers]]
event = "user_invocation"
{{ end }}

[instances.worker]
agent         = "worker"
ephemeral     = true
replicas      = 4
reap_worktree = "on_merge"   # reap the job worktree + local branch after its PR merges; `agent-team job keep-worktree <id>` opts one job out
token_budget  = "40M"
time_budget   = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard = true
# hard_multiplier = 1.5
description   = "Code-writing agent. Spawned on `agent.dispatch` (see assign-worker skill)."

[[instances.worker.triggers]]
event        = "agent.dispatch"
match.target = "worker"

[instances.verifier]
agent        = "verifier"
ephemeral    = true
replicas     = 2
token_budget = "5M"
time_budget  = "20m"
description  = "Deterministic verifier. Runs declared gates against worker commits and writes machine-readable evidence before review."

[[instances.verifier.triggers]]
event        = "agent.dispatch"
match.target = "verifier"

[instances.reviewer]
agent       = "reviewer"
ephemeral   = true
replicas    = 3
token_budget = "10M"
time_budget  = "30m"
env_allow   = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK"]
description = "Adversarial content reviewer for worker PRs. Reads, verifies, reports a verdict; never pushes."

[[instances.reviewer.triggers]]
event        = "agent.dispatch"
match.target = "reviewer"

# The field-proven pipeline shape (see documentation/operating-model.md):
# dragging a Linear card or GitHub Project item into the configured
# agent_column ("Ready for Agent" by default) is the dispatch gesture. The
# zero-config alternative is:
#   trigger.event = "ticket.created"
#   # remove trigger.match.status
#
# Headless implement -> deterministic verify -> adversarial review chain on
# process exit; the manual gate stops exactly where merge judgment is needed.
# Watchdog timeouts rescue wedged runtimes; implement keeps max_attempts = 1
# because a hang can strike after the PR opens and a retry would open a
# duplicate. Verify and review are read-only, so retry_on_crash allows one
# automatic retry only after a crash with no recorded result.
[pipelines.ticket_to_pr]
trigger.event = "ticket.status_changed"
trigger.match.status = "{{ if eq .pm.provider `github` }}{{ .github.agent_column }}{{ else }}{{ .linear.agent_column }}{{ end }}"
auto_advance  = true
redispatch_on_reentry = false

[[pipelines.ticket_to_pr.steps]]
id           = "implement"
target       = "worker"
workspace    = "worktree"
timeout      = "45m"
token_budget = "40M"
time_budget  = "45m"
# Hard cutoffs are off by default. Uncomment only as runaway protection; soft
# budget_notice levels are the normal pacing mechanism.
# hard_multiplier = 1.5
max_attempts = 1

[[pipelines.ticket_to_pr.steps]]
id           = "verify"
target       = "verifier"
after        = ["implement"]
workspace    = "repo"
timeout      = "20m"
token_budget = "5M"
time_budget  = "20m"
max_attempts = 1
retry_on_crash = true
instructions = """
Run the verify skill against the worker commit before LLM review. Stream
progress, write `target/agent-evidence/<job>.json`, record each gate with
`agent-team job gate set`, and advance only if every declared gate passes.

```agent-team-verify-gates
gofmt-check :: test -z "$(gofmt -l .)"
go-vet :: go vet ./...
go-test :: go test ./...
```
"""

[[pipelines.ticket_to_pr.steps]]
id           = "review"
target       = "reviewer"
after        = ["verify"]
timeout      = "30m"
token_budget = "10M"
time_budget  = "30m"
max_attempts = 1
retry_on_crash = true
instructions = """
Read `target/agent-evidence/<job>.json` first, then hand-verify: (1) the
ticket's acceptance criteria are actually met — check the specific behaviors,
not the PR description; (2) tests cover the changed behavior and would fail
without the change; (3) no unrelated files or drive-by edits; (4) no dead code
or commented-out blocks. Judge CONTENT outside the scripted verifier gates:
infra failures are gate results, not bounces, and base drift is not a bounce.
Report via `agent-team job gate set` and a PR comment starting
`REVIEW: APPROVE` or `REVIEW: BOUNCE`.
"""

# The manual gate: nothing merges without human (or manager) judgment. To make
# an explicit approval artifact mandatory before this step can advance, add
# `approval_required = true` and pair it with `agent-team approval request`.
[[pipelines.ticket_to_pr.steps]]
id           = "approve"
target       = "manager"
after        = ["review"]
gate         = "manual"
instructions = """
Read the reviewer's verdict and the diff. If REVIEW: APPROVE and gates are
green, merge with `agent-team job merge <job-id>` (or `gh pr merge`), close the
ticket, and mark the job done. If REVIEW: BOUNCE, run `agent-team job bounce
<job-id> --findings-file <path> --advance` so the worker gets the findings in
kickoff — do not amend the branch yourself.
"""

{{ if eq .template.profile `full` }}

# The feedback-triage loop: agents submit one-line observations mid-job
# (`agent-team feedback submit` — see the triage-feedback skill); this weekly
# schedule spawns an ephemeral manager that clusters new feedback plus system
# pain signals (repeated bounces, infra-signature repeats) and materializes
# tickets, folds evidence into existing ones, or dismisses with a reason.
# Filed tickets land in Backlog — never the agent-dispatch column.
[schedules.feedback-triage]
every = "6h"

[schedules.feedback-triage.payload]
kind = "feedback_triage"

[instances.feedback-triage]
agent       = "manager"
ephemeral   = true
description = "Scheduled feedback triage: local store + system signals -> tickets/folds/dismissals."

[[instances.feedback-triage.triggers]]
event      = "schedule"
match.name = "feedback-triage"
match.kind = "feedback_triage"


