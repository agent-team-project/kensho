# incident feedback immediately. See the sentinel skill.
[schedules.sentinel]
every = "6h"
run_on_start = true

[schedules.sentinel.payload]
kind = "sentinel"

[instances.sentinel]
agent        = "manager"
ephemeral    = true
token_budget = "10M"
time_budget  = "15m"
env_allow    = ["PATH", "HOME", "USER", "LOGNAME", "SHELL", "TMPDIR", "TERM", "TERM_PROGRAM", "LANG", "LC_*", "XDG_*", "CODEX_HOME", "CLAUDE_CODE_*", "SSH_AUTH_SOCK", "AGENT_TEAM_GITHUB_TOKEN", "GITHUB_TOKEN", "GH_TOKEN"]
description  = "Scheduled production sentinel: main CI, RTD rendering, release assets, and repo metadata."

[[instances.sentinel.triggers]]
event      = "schedule"
match.name = "sentinel"
match.kind = "sentinel"


