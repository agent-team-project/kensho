# agent-team configuration for this repo.
#
# Generated by `agent-team init`. Edit values to match your team. Commit this
# file (no secrets — only IDs and labels). API keys belong in .env.

[team]
# Which PM tool the team talks to. Use "none" for ticketless jobs, or "linear"
# after filling in the [linear] section below.
pm_tool   = "none"
local_dir = ".agent_team"

# Team-level shared skills are registered for every launched agent. Use this
# for capabilities that should survive retiring any one instance.
# [skills]
# team = []

# Optional: default LLM runtime for this repo. Environment variables still win:
# AGENT_TEAM_RUNTIME and AGENT_TEAM_RUNTIME_BIN.
# [runtime]
# kind = "claude" # or "codex"
# binary = "claude"

[otel]
# Opt-in runtime telemetry propagation. Disabled means no OTEL env vars,
# Codex config args, or TRACEPARENT are injected into child runtimes.
enabled = false

# OTLP/HTTP collector endpoint used for runtime-owned telemetry when enabled.
# endpoint = "http://localhost:4318"

# Optional static headers for collector requests. Do not commit literal secrets;
# prefer environment substitutions supported by the runtime where possible.
# [otel.headers]
# "x-otlp-api-key" = "${OTLP_TOKEN}"

# Optional custom resource attributes. agent-team-owned attributes such as
# service.name, instance, job, ticket, pipeline, team, runtime, and build
# identity are injected automatically and take precedence on key conflicts.
# [otel.resource]
# "deployment.environment" = "dev"

[health]
# Non-idle/non-done status.toml files older than this are shown as stale.
status_stale_after = "10m"

# Queued or running jobs with no update after this duration appear in triage.
job_stale_after = "24h"

# Terminal jobs and daemon instance records older than this duration are archived
# during maintenance. Use values like "14d"; "0" disables archival.
terminal_retention = "0"

[notifications]
# Daemon-published status phase transitions sent to #supervisor.
# Include "idle" to notify on busy->idle; "blocked" reports any->blocked.
phase_transitions = ["blocked"]

# Optional repeat idle notification while an instance remains idle.
# "0" disables idle repeats.
idle_renotify = "0"

[linear]
# Used only when [team].pm_tool = "linear".
#
# UUID of the Linear team this repo's tickets belong to. Find it via:
#   query { teams(first: 50) { nodes { id key name } } }
team_id       = ""

# Ticket prefix for this team — e.g. "ENG", "BENCH", "SQU".
ticket_prefix = ""

# Column name that dispatches the default ticket_to_pr pipeline when a card is
# moved into it.
agent_column = "Ready for Agent"

# Optional: Linear user UUID for the agent API key. Status-change webhooks
# authored by this user are ignored so agent write-backs do not redispatch work.
# agent_user_id = ""

# Workflow state name used when a job is dispatched or bounced back.
in_progress_state = "In Progress"

# Optional workflow state name used when a job fails and needs attention.
# If unset, failures leave a Linear comment and apply configured labels when present.
# attention_state = "Todo"

# Optional: initiative UUID this team rolls up to.
# initiative_id = ""

# Optional: canonical labels the team applies when relevant.
# labels = ["agent-work"]

[linear.projects]
# Map of project-name → Linear project UUID. Names are semantic — ticket-manager
# uses them to route new tickets. Find UUIDs via:
#   query($teamId: String!) { team(id: $teamId) { projects { nodes { id name } } } }
# general = "..."
# release = "..."

[worktree]
# Where workers create their isolated git worktrees and how to prefix branches.
# Claude Code's Agent tool with isolation: "worktree" sets these up automatically.
path          = ".claude/worktrees"
branch_prefix = "worker/"
